# Job Runner Environment Configuration
# Copy to ~/.job_runner/.env and fill in your values.

# Web UI (optional): shared master password for the dashboard. If set, /login.html is required
# before using the app (same password for you and your assistant). Leave empty for no UI login.
# JOB_RUNNER_UI_PASSWORD=
# Behind HTTPS (e.g. Cloudflare Tunnel), set so the session cookie is Secure:
# JOB_RUNNER_UI_COOKIE_SECURE=1
# Optional explicit signing key (else derived from JOB_RUNNER_UI_PASSWORD when set):
# JOB_RUNNER_SESSION_SECRET=
# When you open the UI from another device on the same Wi‑Fi (e.g. MacBook → PC running job_runner ui --lan),
# allow uploads/saves from that device (private LAN IPs only). Do not enable on untrusted public Wi‑Fi.
# JOB_RUNNER_TRUST_LAN=1
#
# Telegram daemon (scripts/windows/job_runner_daemon.py): branch for /update and optional pip after pull
# JOB_RUNNER_GIT_BRANCH=main
# JOB_RUNNER_TELEGRAM_UPDATE_PIP=1
#
# Auto-deploy from GitHub (daemon polls API; Telegram notify on success/fail). Public repo needs no token.
# JOB_RUNNER_AUTO_UPDATE_FROM_GITHUB=1
# JOB_RUNNER_AUTO_UPDATE_INTERVAL_SEC=120
# JOB_RUNNER_GITHUB_REPO=owner/repo
# JOB_RUNNER_GITHUB_TOKEN=
# Telegram notifications + daemon control + remote clipboard from Telegram:
# JOB_RUNNER_TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
# JOB_RUNNER_TELEGRAM_CHAT_ID=123456789
# Optional explicit admin chat id for daemon commands/clipboard (defaults to CHAT_ID):
# JOB_RUNNER_TELEGRAM_ADMIN_ID=123456789
#
# Optional remote desktop launcher via Telegram:
# /remote runs JOB_RUNNER_REMOTE_START_CMD
# /remote_stop runs JOB_RUNNER_REMOTE_STOP_CMD (if set)
# /remote_status returns whether the launcher process is still running
# JOB_RUNNER_REMOTE_START_CMD=Start-Process "C:\Program Files\RustDesk\rustdesk.exe"
# JOB_RUNNER_REMOTE_STOP_CMD=Get-Process rustdesk -ErrorAction SilentlyContinue | Stop-Process -Force
# JOB_RUNNER_REMOTE_INFO_TEXT=Open RustDesk on iPhone and connect to this laptop's RustDesk ID.

# LLM Provider (pick one)
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, cheapest)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama)
# LLM_MODEL=              # Override model name
# Seconds between LLM scoring requests (rate limits; default 4.5)
JOB_RUNNER_LLM_DELAY=4.5

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Apply agent: openai (default if OPENAI_API_KEY set) uses gpt-4.1-mini + Playwright CDP (cheaper).
# claude uses Claude Code CLI + @playwright/mcp (original).
# JOB_RUNNER_APPLY_AGENT=openai
# JOB_RUNNER_APPLY_OPENAI_MODEL=gpt-4.1-mini
# Optional OpenAI-compatible endpoint override for apply agent (DeepSeek/OpenRouter/etc):
# JOB_RUNNER_APPLY_OPENAI_BASE_URL=https://api.deepseek.com
# JOB_RUNNER_APPLY_OPENAI_API_KEY=sk-...
# Example DeepSeek model:
# JOB_RUNNER_APPLY_OPENAI_MODEL=deepseek-chat
# JOB_RUNNER_APPLY_DETERMINISTIC_FIRST=1   # Fast checks (e.g. expired LinkedIn) before LLM
# JOB_RUNNER_APPLY_OPENAI_MAX_TURNS=12     # Cap tool/model turns per job

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
