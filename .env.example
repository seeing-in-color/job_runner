# Job Runner Environment Configuration
# Copy to ~/.job_runner/.env and fill in your values.

# Web UI (optional): shared master password for the dashboard. If set, /login.html is required
# before using the app (same password for you and your assistant). Leave empty for no UI login.
# JOB_RUNNER_UI_PASSWORD=
# Behind HTTPS (e.g. Cloudflare Tunnel), set so the session cookie is Secure:
# JOB_RUNNER_UI_COOKIE_SECURE=1
# Optional explicit signing key (else derived from JOB_RUNNER_UI_PASSWORD when set):
# JOB_RUNNER_SESSION_SECRET=

# LLM Provider (pick one)
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, cheapest)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama)
# LLM_MODEL=              # Override model name
# Seconds between LLM scoring requests (rate limits; default 4.5)
JOB_RUNNER_LLM_DELAY=4.5

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Apply agent: openai (default if OPENAI_API_KEY set) uses gpt-4.1-mini + Playwright CDP (cheaper).
# claude uses Claude Code CLI + @playwright/mcp (original).
# JOB_RUNNER_APPLY_AGENT=openai
# JOB_RUNNER_APPLY_OPENAI_MODEL=gpt-4.1-mini
# JOB_RUNNER_APPLY_DETERMINISTIC_FIRST=1   # Fast checks (e.g. expired LinkedIn) before LLM
# JOB_RUNNER_APPLY_OPENAI_MAX_TURNS=12     # Cap tool/model turns per job

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
